        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are a clinical NLP assistant for ER triage. Extract structured fields from the nurse's transcribed chief complaint. Return JSON only.\nNever infer beyond what is stated. If a field is unclear, return null.\n\nReturn this schema:\n{\n  \"complaint_category\": \"string — primary clinical category, most specific label that fits the complaint\",\n  \"complaint_category_alternatives\": [\"string\", \"string\"] or [] — up to 2 alternative category labels if the complaint is ambiguous or could reasonably be classified differently. Empty array if the primary is unambiguous.\",\n  \"onset\": \"string\",\n  \"duration\": \"string\",\n  \"symptoms\": [\"string\"],\n  \"trigger\": \"string or null\",\n  \"context\": \"string or null\"\n}"
            },
            {
              "role": "user",
              "content": "{{ $json.body.complaint_text }}"
            }
          ]
        },
        "options": {
          "responseFormat": "json_object",
          "temperature": 0
        }
      },
      "credentials": {
        "openAiApi": {
          "id": "REPLACE_WITH_YOUR_CREDENTIAL_ID",
          "name": "OpenAI API"
        }
      }
    },
    {
